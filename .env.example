# ─────────────────────────────────────────────────────────────
# Bible Crawler — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control (it is already in .gitignore).
# All values below are the built-in defaults; uncomment and change
# only what you need to override.


# ── Application ──────────────────────────────────────────────
APP_ENV=development


# ── Database (required by cmd/crawler) ───────────────────────
# Full PostgreSQL DSN. Adjust host, port, user, password, dbname.
DATABASE_URL=postgres://username:password@localhost:5432/database_name?sslmode=disable


# ── Source website ───────────────────────────────────────────
# Update these three values if:
#   • The website moves to a new domain or changes its URL structure.
#   • You want to switch the Chinese version to a different translation
#     (e.g. from 和合本 CUV to another version with a different URL param).
#   • You want to switch the English version to a different translation
#     (e.g. from BBE to KJV — change the "ver=bbe" parameter).
#
# URL templates must contain exactly one %d placeholder, which is replaced
# with the global chapter index (1-based sequential number across all 66 books:
# Genesis ch1 = 1, Genesis ch50 = 50, Exodus ch1 = 51, … Revelation ch22 = 1189).
#
SOURCE_DOMAIN=springbible.fhl.net
SOURCE_ZH_URL=https://springbible.fhl.net/Bible2/cgic201/read201.cgi?na=0&chap=%d&ft=0
SOURCE_EN_URL =https://springbible.fhl.net/Bible2/cgic201/read201.cgi?na=0&chap=%d&ver=bbe

# ── Crawler tuning ───────────────────────────────────────────
# Reduce CRAWLER_PARALLELISM or increase CRAWLER_DELAY_MS if the
# source server starts returning errors or throttling requests.
#
# CRAWLER_PARALLELISM   — max concurrent outbound HTTP requests (default: 5)
# CRAWLER_DELAY_MS      — base delay between requests in milliseconds (default: 200)
# CRAWLER_RANDOM_DELAY_MS — extra random jitter added to each delay (default: 100)
# HTTP_TIMEOUT_SEC      — per-request HTTP timeout in seconds (default: 30)
#
CRAWLER_PARALLELISM=5
CRAWLER_DELAY_MS=200
CRAWLER_RANDOM_DELAY_MS=100
HTTP_TIMEOUT_SEC=10

# ── YouVersion API ────────────────────────────────────────────────────────────
# Required only when running cmd/youversion-crawler or cmd/youversion-importer.
# Obtain an app key at https://platform.youversion.com
#
YOUVERSION_API_KEY=your-app-key-here
YOUVERSION_BASE_URL=https://api.youversion.com/v1

# Bible version IDs used for English and Chinese content.
# Default: 111 = NIV 2011 (English), 312 = CSB 中文標準譯本 (Chinese Standard Bible, traditional Chinese).
# To use a different translation, set YOUVERSION_CHINESE_BIBLE_ID to the desired Bible ID.
YOUVERSION_CHINESE_BIBLE_ID=312
YOUVERSION_ENGLISH_BIBLE_ID=111

# ── YouVersion Parallel Mode (optional) ────────────────────────────────────────
# When YOUVERSION_CHECKPOINT_FILE is set to a file path, cmd/youversion-crawler
# switches to parallel mode:
#   • Phase 2 fetches verses using N worker goroutines with rate limiting
#     and exponential-backoff retry, writing results to a JSONL file.
#   • Press Ctrl+C to stop gracefully; restart the crawler to resume from
#     where it left off (already-fetched verses are skipped automatically).
#   • After the crawl finishes, run cmd/youversion-importer to batch-write
#     the JSONL file into PostgreSQL.
#
# Leave YOUVERSION_CHECKPOINT_FILE empty (or unset) for the original
# sequential mode: verses are written directly to the DB, no importer needed.
#
YOUVERSION_CHECKPOINT_FILE=ckpoint.jsonl

# Number of parallel worker goroutines.
# Should be >= YOUVERSION_RATE_LIMIT_RPS so workers don't idle waiting for tokens.
YOUVERSION_WORKERS=20

# Token-bucket rate limit: maximum requests per second across all workers.
# At 15 RPS the full ~62,200-verse crawl (EN + ZH) completes in ≈ 70 minutes.
# With an existing checkpoint the remaining portion finishes sooner.
# Reduce if you observe 429 Too Many Requests responses.
YOUVERSION_RATE_LIMIT_RPS=15.0

# Maximum retry attempts per verse on network errors or 5xx responses.
# 404 responses are never retried — they indicate a verse genuinely absent from
# the translation (e.g. NIV omits MAT.17.21, MAT.18.11, etc.).
YOUVERSION_MAX_RETRIES=3

# Initial exponential-backoff interval in milliseconds.
# Each retry doubles the wait (±25 % jitter), up to a 60-second maximum.
YOUVERSION_RETRY_BASE_MS=500